  "author": "Fabio Renner",
  "license": "Apache-2.0",
  "homepage": "https://github.com/fabiorenner-hub/hmip-hcu-velux_klf200#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fabiorenner-hub/hmip-hcu-velux_klf200.git"
  },
  "bugs": {
    "url": "https://github.com/fabiorenner-hub/hmip-hcu-velux_klf200/issues"
  },
  "keywords": [
    "homematic",
    "hmip",
    "hcu",
    "velux",
    "klf-200",
    "io-homecontrol",
    "shutter",
    "smart-home"
  ],
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
